// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CONTENIDISTA
  COORDINADOR
  DIRECCION
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?  // Hashed — null para usuarios de Google
  googleId  String?  @unique @map("google_id")
  name      String
  role      UserRole
  areaId    String?  @map("area_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  area    Area?    @relation(fields: [areaId], references: [id])
  tickets Ticket[]
  clients Client[]

  @@map("users")
}

model Client {
  id            String   @id @default(uuid())
  name          String
  active        Boolean  @default(true)
  ownerId       String?  @map("owner_id")
  canales       String[] @default([])
  linkedinUrl   String?  @map("linkedin_url")
  instagramUrl  String?  @map("instagram_url")
  twitterUrl    String?  @map("twitter_url")
  tiktokUrl     String?  @map("tiktok_url")
  webUrl        String?  @map("web_url")
  newsletterUrl String?  @map("newsletter_url")
  blogUrl       String?  @map("blog_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  owner        User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  tickets      Ticket[]
  brandVoice   BrandVoice?
  publications Publication[]
  speakers     Speaker[]
  pilares      Pilar[]

  @@index([ownerId])
  @@map("clients")
}

model Speaker {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  nombre    String
  cargo     String?

  // Redes sociales del vocero
  linkedinUrl   String? @map("linkedin_url")
  instagramUrl  String? @map("instagram_url")
  twitterUrl    String? @map("twitter_url")
  tiktokUrl     String? @map("tiktok_url")
  newsletterUrl String? @map("newsletter_url")
  blogUrl       String? @map("blog_url")

  // Canales habilitados (JSON: { linkedin: true, instagram: false, ... })
  canalesHabilitados Json @default("{}") @map("canales_habilitados")

  // 9 campos Voz del Vocero
  personalidadArquetipo  String? @db.Text @map("personalidad_arquetipo")
  tonoVozPersonal        String? @db.Text @map("tono_voz_personal")
  contextoExperiencia    String? @db.Text @map("contexto_experiencia")
  temasHabla             String? @db.Text @map("temas_habla")
  posicionamientoOpinion String? @db.Text @map("posicionamiento_opinion")
  estructuraNarrativa    String? @db.Text @map("estructura_narrativa")
  usoIdioma              String? @db.Text @map("uso_idioma")
  criteriosCalidad       String? @db.Text @map("criterios_calidad")
  contextoMarca          String? @db.Text @map("contexto_marca")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tickets      Ticket[]
  publications Publication[]

  @@index([clientId])
  @@map("speakers")
}

model Pilar {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")
  nombre      String
  descripcion String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@index([clientId])
  @@map("pilares")
}

model BrandVoice {
  id        String   @id @default(uuid())
  clientId  String   @unique @map("client_id")
  content   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("brand_voices")
}

model Area {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users   User[]

  @@map("areas")
}

model TicketType {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tickets Ticket[]

  @@map("ticket_types")
}

enum TicketStatus {
  BACKLOG
  BRIEF
  CONTENIDO
  DISENO
  REVISION
  APROBADO
  CANCELADO
}

enum Prioridad {
  ALTA
  MEDIA
  BAJA
}

model Ticket {
  id           String         @id @default(uuid())
  title        String
  objetivo     String?        @db.Text
  description  String?        @db.Text
  canales      String[]       @default([])
  clientId     String         @map("client_id")
  ownerId      String         @map("owner_id")
  ticketTypeId String?        @map("ticket_type_id")
  pilarId      String?        @map("pilar_id")
  speakerId    String?        @map("speaker_id")
  status       TicketStatus   @default(BACKLOG)
  prioridad    Prioridad      @default(MEDIA)
  dueDate      DateTime?      @map("due_date")
  content      String?        @db.Text
  contentPerCanal Json        @default("{}") @map("content_per_canal")
  keywords     String?
  links           String[]       @default([])
  linkEntregable  String?        @map("link_entregable")
  notasAudiovisual String?       @db.Text @map("notas_audiovisual")
  chatHistory     Json?          @map("chat_history")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  // Relations
  client      Client       @relation(fields: [clientId], references: [id])
  owner       User         @relation(fields: [ownerId], references: [id])
  ticketType  TicketType?  @relation(fields: [ticketTypeId], references: [id])
  pilar       Pilar?       @relation(fields: [pilarId], references: [id])
  speaker     Speaker?     @relation(fields: [speakerId], references: [id])
  publication Publication?

  @@index([clientId])
  @@index([ownerId])
  @@index([status])
  @@index([status, createdAt])
  @@index([clientId, status])
  @@index([pilarId])
  @@index([speakerId])
  @@map("tickets")
}

model Publication {
  id          String    @id @default(uuid())
  ticketId    String?   @unique @map("ticket_id")       // null si fue scrapeado automáticamente
  clientId    String    @map("client_id")               // siempre tiene cliente
  speakerId   String?   @map("speaker_id")              // null si es publicación de marca (no vocero)
  url         String    @unique                         // URL del post — evita duplicados
  publishedAt DateTime  @map("published_at")
  canal       String    @default("LinkedIn")
  imageUrl    String?   @map("image_url")
  postContent String?   @db.Text @map("post_content")  // texto del post scrapeado
  isHighlight Boolean   @default(false) @map("is_highlight")
  tags        String[]  @default([])
  insights    String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  ticket    Ticket?              @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  client    Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  speaker   Speaker?             @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  snapshots PostMetricSnapshot[]

  @@index([clientId])
  @@index([speakerId])
  @@map("publications")
}

model PostMetricSnapshot {
  id            String      @id @default(uuid())
  publicationId String      @map("publication_id")
  dayNumber     Int         @map("day_number") // 1-5 = snapshots diarios, 99 = foto final (se pisa)
  likes         Int         @default(0)
  comments      Int         @default(0)
  shares        Int         @default(0)
  takenAt       DateTime    @default(now()) @map("taken_at")

  publication Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@unique([publicationId, dayNumber])
  @@index([publicationId])
  @@map("post_metric_snapshots")
}
